# ─── API Keys ────────────────────────────────────────────────
# Deepgram: https://console.deepgram.com/ (бесплатно $200 кредитов)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Perplexity: https://www.perplexity.ai/settings/api
# Оставить пустым для работы полностью offline
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ─── LLM Routing Strategy ────────────────────────────────────
# auto     — Perplexity если есть ключ, иначе Ollama
# fallback — Perplexity → при ошибке Ollama (рекомендуется)
# local    — только Ollama, без интернета
# cloud    — только Perplexity
# parallel — оба параллельно, быстрейший выигрывает
LLM_STRATEGY=fallback

# ─── Ollama / Local Qwen ─────────────────────────────────────
# Установка: https://ollama.com
# Модели (выбери одну под свой VRAM):
#   qwen2.5:7b-instruct-q4_K_M   ~4.5 GB VRAM ← рекомендуется RTX 5050 8GB
#   qwen2.5:14b-instruct-q4_K_M  ~8.0 GB VRAM ← максимальное качество
#   qwen3:8b-q4_K_M              ~5.0 GB VRAM ← Qwen3 если установлен
# Команда: ollama pull qwen2.5:7b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=20

# ─── Backend ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Frontend ────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
